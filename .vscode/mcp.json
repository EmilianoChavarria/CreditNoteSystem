{
	"servers": {
		"angular-cli": {
			"command": "npx",
			"args": [
				"-y",
				"@angular/cli",
				"mcp"
			],
			"type": "stdio"
		},
		"console-ninja": {
			"command": "powershell.exe",
			"args": [
				"node",
				"$Env:USERPROFILE/.console-ninja/mcp/"
			],
			"type": "stdio"
		}
	},
	"inputs": []
}