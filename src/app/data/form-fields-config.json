{
  "credits": {
    "tabs": [
      {
        "id": 1,
        "title": "Request & Customer",
        "fields": [
          {
            "formControlName": "requestNumber",
            "label": "Request Number",
            "type": "text",
            "placeholder": "Auto-generated",
            "validators": [],
            "disabled": true,
            "description": "Se genera en automático"
          },
          {
            "formControlName": "orderNumber",
            "label": "Order Number",
            "type": "text",
            "placeholder": "Ingrese número de orden",
            "validators": [],
            "description": "Llenado manual post-nota"
          },
          {
            "formControlName": "creditNumber",
            "label": "Credit Number",
            "type": "text",
            "placeholder": "Folio de crédito",
            "validators": [],
            "description": "Folio de crédito final"
          },
          {
            "formControlName": "requestDate",
            "label": "Request Date",
            "type": "date",
            "placeholder": "",
            "validators": ["required"],
            "defaultValue": "today",
            "description": "Default: Fecha de hoy"
          },
          {
            "formControlName": "customerId",
            "label": "Customer Number",
            "type": "autocomplete",
            "placeholder": "Buscar cliente",
            "validators": ["required"],
            "dataSource": "customers",
            "description": "Listado de clientes"
          },
          {
            "formControlName": "area",
            "label": "Area",
            "type": "select",
            "placeholder": "Seleccione área",
            "validators": ["required"],
            "options": [
              { "value": "original-equipment", "label": "Original Equipment" },
              { "value": "market", "label": "Market" }
            ]
          },
          {
            "formControlName": "reasonId",
            "label": "Reason Why",
            "type": "select",
            "placeholder": "Seleccione razón",
            "validators": ["required"],
            "options": [
              { "value": "original-equipment", "label": "Original Equipment" },
              { "value": "market", "label": "Market" }
            ],
            "dataSource": "reasons",
            "description": "Opciones de motivo de solicitud"
          },
          {
            "formControlName": "classificationId",
            "label": "Classification",
            "type": "select",
            "placeholder": "Seleccione clasificación",
            "validators": ["required"],
            "options": [
              { "value": "original-equipment", "label": "Original Equipment" },
              { "value": "market", "label": "Market" }
            ],
            "dataSource": "classifications",
            "description": "Clasificación de la nota"
          }
        ]
      },
      {
        "id": 2,
        "title": "Reference & Logistics",
        "fields": [
          {
            "formControlName": "deliveryNote",
            "label": "Delivery Note",
            "type": "text",
            "placeholder": "Referencia de entrega",
            "validators": []
          },
          {
            "formControlName": "invoiceNumber",
            "label": "Invoice Number",
            "type": "text",
            "placeholder": "Número de factura original",
            "validators": ["required"]
          },
          {
            "formControlName": "invoiceDate",
            "label": "Invoice Date",
            "type": "date",
            "placeholder": "",
            "validators": ["required"],
            "description": "Fecha de factura original"
          },
          {
            "formControlName": "sapScreen",
            "label": "SAP Screen",
            "type": "file",
            "placeholder": "Seleccione captura de pantalla",
            "validators": [],
            "accept": "image/*",
            "description": "Captura de pantalla SAP (Evidencia)"
          }
        ]
      },
      {
        "id": 3,
        "title": "Financial Data",
        "fields": [
          {
            "formControlName": "currency",
            "label": "Currency",
            "type": "select",
            "placeholder": "Seleccione moneda",
            "validators": ["required"],
            "options": [
              { "value": "USD", "label": "USD" },
              { "value": "MXN", "label": "MXN" }
            ]
          },
          {
            "formControlName": "exchangeRate",
            "label": "Exchange Rate",
            "type": "number",
            "placeholder": "Tipo de cambio",
            "validators": ["required", "min:0"],
            "step": 0.0001,
            "description": "1 si es MXN, valor actual si es USD"
          },
          {
            "formControlName": "amount",
            "label": "Amount",
            "type": "number",
            "placeholder": "0.00",
            "validators": ["required", "min:0"],
            "step": 0.01,
            "description": "Monto principal"
          },
          {
            "formControlName": "hasIva",
            "label": "IVA",
            "type": "checkbox",
            "placeholder": "",
            "validators": [],
            "description": "Cálculo del 16% sobre Amount"
          },
          {
            "formControlName": "totalAmount",
            "label": "Total",
            "type": "computed",
            "placeholder": "",
            "validators": [],
            "disabled": true,
            "description": "Monto + IVA (Label dinámico)",
            "computeFrom": ["amount", "hasIva"],
            "formula": "hasIva ? amount * 1.16 : amount"
          }
        ]
      },
      {
        "id": 4,
        "title": "Review & Finalize",
        "fields": [
          {
            "formControlName": "attachSupports",
            "label": "Attach Supports",
            "type": "file",
            "placeholder": "Adjuntar soportes",
            "validators": [],
            "accept": ".pdf,.jpg,.png,.xlsx",
            "description": "Incluye memoria de cálculo"
          },
          {
            "formControlName": "comments",
            "label": "Comments",
            "type": "textarea",
            "placeholder": "Comentarios tipo SAT",
            "validators": [],
            "rows": 4
          },
          {
            "formControlName": "reviewComments",
            "label": "Review Comments",
            "type": "textarea",
            "placeholder": "Comentarios de auditoría",
            "validators": [],
            "rows": 3,
            "readonly": true,
            "description": "Comentarios de auditoría (Solo lectura/Admin)"
          },
          {
            "formControlName": "status",
            "label": "Status de la nota",
            "type": "badge",
            "placeholder": "",
            "validators": [],
            "disabled": true,
            "description": "Estatus actual del proceso"
          }
        ]
      }
    ]
  },
